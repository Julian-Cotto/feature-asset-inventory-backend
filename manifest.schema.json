{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Feature Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "featureKey",
    "version",
    "displayName",
    "basePath",
    "frontend",
    "backend",
    "auth",
    "authorization",
    "registry",
    "events",
    "workers"
  ],
  "properties": {
    "featureKey": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "basePath": {
      "type": "string",
      "pattern": "^/.*"
    },
    "route": {
      "type": "string",
      "pattern": "^/.*"
    },
    "navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "icon"],
      "properties": {
        "label": { "type": "string" },
        "icon": { "type": "string" }
      }
    },
    "nav": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "icon"],
      "properties": {
        "label": { "type": "string" },
        "icon": { "type": "string" }
      }
    },
    "frontend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "entryStrategy", "entryUrl", "mountFunction"],
      "properties": {
        "enabled": { "type": "boolean" },
        "entryStrategy": { "type": "string" },
        "entryUrl": { "type": "string" },
        "mountFunction": { "type": "string" }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "baseUrl", "healthEndpoint"],
      "properties": {
        "enabled": { "type": "boolean" },
        "baseUrl": { "type": "string" },
        "apiBaseUrl": { "type": "string" },
        "healthEndpoint": { "type": "string" }
      }
    },
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "mode",
        "shellAuthRequired",
        "tokenForwarding",
        "tokenStrategy",
        "allowedDevModes",
        "roles"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": ["entra", "mock", "none"]
        },
        "shellAuthRequired": {
          "type": "boolean"
        },
        "tokenForwarding": {
          "type": "boolean"
        },
        "tokenStrategy": {
          "type": "string",
          "enum": [
            "forwarded-bearer",
            "shell-session",
            "none",
            "forward_access_token"
          ]
        },
        "allowedDevModes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["entra", "mock", "none"]
          }
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredPermissions", "requiredFlags"],
      "properties": {
        "requiredPermissions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+\\.[a-z0-9-]+$"
          }
        },
        "requiredFlags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+\\.[a-z0-9-]+$"
          }
        }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "mode"],
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": {
          "type": "string",
          "enum": ["rest", "file", "none"]
        }
      }
    },
    "events": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publishes", "consumes"],
      "properties": {
        "publishes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+(\\.[a-z0-9-]+)+$"
          }
        },
        "consumes": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+(\\.[a-z0-9-]+)+$"
          }
        }
      }
    },
    "workers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scheduledJobs", "eventDrivenJobs", "eventListeners"],
      "properties": {
        "scheduledJobs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "eventDrivenJobs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "eventListeners": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "environment": {
      "type": "string",
      "enum": ["local", "dev", "test", "prod"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ownerTeam"],
      "properties": {
        "ownerTeam": { "type": "string", "minLength": 1 },
        "commitSha": { "type": ["string", "null"] },
        "buildId": { "type": ["string", "null"] },
        "releaseDate": { "type": ["string", "null"] }
      }
    }
  }
}