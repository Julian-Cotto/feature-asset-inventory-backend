FEATURE_KEY=asset-inventory
FEATURE_BASE_PATH=/inventory/it
FEATURE_API_BASE_PATH=/api/inventory/it
AUTH_MODE=entra
REGISTRY_MODE=rest
LOCAL_FRONTEND_URL=http://localhost:3100
LOCAL_BACKEND_URL=http://localhost:8000/api/inventory/it

# Vendor lookup providers (optional; lookup is best-effort)
# MERAKI_API_KEY=         # from Meraki dashboard, per-org
# MERAKI_ORG_ID=          # numeric org ID
# LENOVO_LOOKUP_ENABLED=true
# LOOKUP_CACHE_TTL_HOURS=168
# LOOKUP_HTTP_TIMEOUT_SECONDS=6.0

# Carrier tracking (UPS + FedEx OAuth2 client-credentials)
# UPS_CLIENT_ID=
# UPS_CLIENT_SECRET=
# UPS_BASE_URL=https://onlinetools.ups.com   # sandbox: wwwcie.ups.com
# FEDEX_API_KEY=
# FEDEX_SECRET_KEY=
# FEDEX_BASE_URL=https://apis.fedex.com      # sandbox: apis-sandbox.fedex.com
# TRACKING_HTTP_TIMEOUT_SECONDS=10.0
# TRACKING_AUTO_REFRESH_MINUTES=15

# Microsoft Intune (Graph API, OAuth2 client-credentials)
# Required Graph permissions on the app reg:
#   DeviceManagementManagedDevices.Read.All  (admin-consented)
# INTUNE_TENANT_ID=
# INTUNE_CLIENT_ID=
# INTUNE_CLIENT_SECRET=